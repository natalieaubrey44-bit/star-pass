# .env.example
# Copy this file to .env and fill in your Supabase project settings.
# NEVER commit .env to version control - it is excluded by .gitignore.
# IMPORTANT: VITE_ variables are exposed in the browser. Do NOT put service role keys here.

VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
